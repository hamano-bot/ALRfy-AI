# ログイン表示名・テーマ初期値: クライアントは GET /api/portal/me（BFF）のみ。上流は PORTAL_API_BASE_URL + /portal/api/me

# 議事録の表示名・リンクはポータル GET /apps（DB の apps）を優先。未接続時のみフォールバック URL を使用（NEXT_PUBLIC_MEETING_URL は未使用）

# 実効ロール（案件単位）表示用: URL に ?project_id= が無いときのフォールバック（任意・開発向け）
# NEXT_PUBLIC_DEFAULT_PROJECT_ID=1

# 開発時のみ: ブラウザの「表示元」と一致させる（Next 15 が /_next/static の CSS を拒否するとスタイルが一切当たらない）。
# next.config は起動時に LAN の IPv4×ポートを自動追加する。足りないときだけ追記。
# NEXT_DEV_ALLOWED_ORIGINS=10.0.0.5:8001
# 自動追加に使うポート（カンマ区切り。既定は 8001,3000 = dev:lan と素の next dev）
# NEXT_DEV_PORTS=8001,3000,5173
#
# --- 開発の安定化（毎回サーバー再起動を減らす） ---
# 1) スタイルが当たらない・Internal Server Error のあと: `npm run dev:lan:reset`（.next を消してから dev）
# 2) HMR が怪しい（Windows）: 既に next.config の webpack で poll あり。ファイル保存で反映されないときだけ reset
# 3) 別ホスト名で開く: 上記 NEXT_DEV_ALLOWED_ORIGINS に「ホスト:ポート」を追加してから Next を再起動
# 4) 本番相当の確認: `npm run build && npm run start:lan`（dev 専用の allowedDevOrigins は本番では無関係）

# ヒアリング Excel 取り込み（サーバー専用。Gemini で表→items マッピング）
# GEMINI_API_KEY=
# 省略時は gemini-3-flash-preview
# GEMINI_MODEL=gemini-3-flash-preview

# 日次ヒアリングテンプレ insight（`POST /api/cron/hearing-template-insight` とポータル Cron API で共通）
# HEARING_INSIGHT_CRON_SECRET=

# BFF → platform-common（サーバー専用。NEXT_PUBLIC にしない）
# Next のプロセスから PHP へ HTTP で届く URL（末尾スラッシュなし）。
# ブラウザは http://dev-alrfy-ai.com:8001/login のみでよい（PHP へは Next がプロキシ）。
# PORTAL_API_BASE_URL=http://127.0.0.1:8000
# BASE と別の upstream にしたいときだけ（省略時は BASE と同じ）
# PORTAL_API_INTERNAL_URL=http://127.0.0.1:8000

# --- 要件定義: 画像アップロード（S3。開発・本番で同じキー規則 `projects/{projectId}/requirements/images/...`）---
# バケット名（必須）
# REQUIREMENTS_S3_BUCKET=your-bucket
# オブジェクト URL のベース（末尾スラッシュなし）。バーチャルホスト形式の例:
# REQUIREMENTS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-northeast-1.amazonaws.com
# CloudFront や静的サイト配信を使う場合はそのオリジン URL に置き換え。
# リージョン（省略時 ap-northeast-1）
# AWS_REGION=ap-northeast-1
# IAM ユーザー鍵（ローカル・CI）。本番 ECS 等ではタスクロールで十分な場合あり。
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# 環境別にオブジェクトキー先頭へ付ける（末尾スラッシュなし）。例: dev / stg / prod でバケットを分けないとき
# REQUIREMENTS_S3_KEY_PREFIX=dev
# 上限バイト（省略時 10485760 = 10MB）
# REQUIREMENTS_S3_MAX_FILE_BYTES=10485760
# LocalStack 等の互換エンドポイント（開発時のみ）。指定時はパススタイルで PUT。
# REQUIREMENTS_S3_ENDPOINT=http://localhost:4566
# 互換エンドポイント用の別名（どちらか）
# AWS_S3_ENDPOINT=http://localhost:4566
#
# --- 開発 PC: S3 を LocalStack で疑似的に再現（データは apps/web/.localstack に保存・本番と同じ AWS SDK / キー）---
# 1) Docker Desktop 起動後、project-manager/apps/web で: npm run localstack:up
# 2) 初回のみ: npm run localstack:init （バケット作成・ブラウザ表示用の公開読み取りポリシー。開発専用）
# 3) 下記を .env.local に設定（init のログに出る PUBLIC_BASE と揃える）
# REQUIREMENTS_S3_BUCKET=alrfy-requirements-local
# REQUIREMENTS_S3_ENDPOINT=http://127.0.0.1:4566
# REQUIREMENTS_S3_PUBLIC_BASE_URL=http://127.0.0.1:4566/alrfy-requirements-local
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# （Next の PutObject は REQUIREMENTS_S3_ENDPOINT があると test 鍵をデフォルトにする。本番では endpoint を付けないこと）

{
  "name": "project-manager-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) { if (!e || e.code !== 'ENOENT') throw e; }\"",
    "dev": "node ./node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "node ./node_modules/next/dist/bin/next dev --turbopack",
    "dev:lan": "node ./node_modules/kill-port/cli.js 8001 && node ./node_modules/next/dist/bin/next dev --webpack -p 8001 -H 0.0.0.0",
    "dev:lan:turbo": "node ./node_modules/kill-port/cli.js 8001 && node ./node_modules/next/dist/bin/next dev --turbopack -p 8001 -H 0.0.0.0",
    "dev:lan:reset": "node ./node_modules/kill-port/cli.js 8001 && npm run clean && node ./node_modules/next/dist/bin/next dev --webpack -p 8001 -H 0.0.0.0",
    "build": "node ./node_modules/next/dist/bin/next build",
    "rebuild": "npm run clean && npm run build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "start:lan": "node ./node_modules/next/dist/bin/next start -p 8001 -H 0.0.0.0",
    "lint": "eslint .",
    "localstack:up": "docker compose -f docker-compose.localstack.yml up -d",
    "localstack:down": "docker compose -f docker-compose.localstack.yml down",
    "localstack:init": "node ./scripts/init-localstack-requirements-s3.mjs",
    "repair": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/repair-node-modules.ps1",
    "repair:admin": "node -e \"require('child_process').execSync('explorer /select,'+require('path').resolve('scripts/repair-node-modules-admin.cmd'),{stdio:'inherit'})\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@floating-ui/dom": "^1.7.6",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-bubble-menu": "^3.22.4",
    "@tiptap/extension-collaboration": "^3.22.4",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-drag-handle": "^3.22.4",
    "@tiptap/extension-font-family": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-node-range": "^3.22.4",
    "@tiptap/extension-ordered-list": "3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table": "3.22.4",
    "@tiptap/extension-table-cell": "3.22.4",
    "@tiptap/extension-table-header": "3.22.4",
    "@tiptap/extension-table-row": "3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.22.4",
    "@tiptap/y-tiptap": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "japanese-holidays": "^1.0.10",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "yjs": "^13.6.30",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}

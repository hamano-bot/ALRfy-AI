{
  "name": "project-manager-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) { if (!e || e.code !== 'ENOENT') throw e; }\"",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:lan": "kill-port 8001 && next dev -p 8001 -H 0.0.0.0",
    "dev:lan:turbo": "kill-port 8001 && next dev --turbopack -p 8001 -H 0.0.0.0",
    "dev:lan:reset": "kill-port 8001 && npm run clean && next dev -p 8001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start -p 8001 -H 0.0.0.0",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}

# このファイルをコピーして `.env.platform-common` にリネームし、
# ホストPCの PHP（php -S）から届く MySQL に合わせて編集する。
#
# minutes_record_dev/.env の DB_DSN は Docker 用（host=db）のため、
# 名前解決できず auth_failed になる。platform-common 単体で動かすときは本ファイルが必要。
#
# minutes_record_dev を docker-compose.dev.yml で起動している場合、
# MySQL はホストから 127.0.0.1:3308 で届く（compose 内の 3306 が 3308 にマップ）。
# DB が止まっている・別ポートのときは DB_DSN だけ合わせる。

DB_DSN=mysql:host=127.0.0.1;port=3308;dbname=minutes_record_db;charset=utf8mb4
DB_USER=root
DB_PASSWORD=root

# 1: project_members / resource_members を見ずに常に所属あり扱い（ACL 未導入時）
# 0: 実所属チェック（database/migrations/20260417_platform_acl_and_apps.sql 適用後 + メンバー行が必要）
# 開発: マイグレーションと seeds/20260417_dev_default_project_members.sql 後に 0 へ
PLATFORM_COMMON_SKIP_MEMBERSHIP_CHECK=1

# 議事録: ダッシュボードのリンク先（platform-common の /minutes を推奨）
# MINUTES_RECORD_PORTAL_URL=http://dev-ALRfy-AI.com:8001/minutes
#
# /minutes が 302 リダイレクトする先（議事録の会議一覧）
# 開発スタック: http://minutes-record.com:8081/meetings
# 本番相当:      http://minutes-record.com:8080/meetings
# MINUTES_RECORD_MEETINGS_URL=http://minutes-record.com:8081/meetings
#
# 案件管理: Next の `/project-list` へのパス（上書きしたいときだけフル URL）
# PROJECT_MANAGER_PORTAL_URL=http://dev-ALRfy-AI.com:8001/project-list

{
  "mcpServers": {
    "chrome-devtools": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--viewport",
        "1280x720",
        "--redact-network-headers"
      ],
      "env": {
        "SystemRoot": "C:\\Windows",
        "ProgramFiles": "C:\\Program Files",
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
      }
    }
  }
}
